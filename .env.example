# Copia questo file in .env e inserisci la tua chiave DeepSeek.
# In sviluppo metti .env nella root del progetto.
# Nella versione portable metti .env accanto a "Agent Ordinatore.exe".

DEEPSEEK_API_KEY=sk-your_deepseek_api_key_here

# Opzionale: se non vuoi scegliere il modello dalle Impostazioni.
# Valori supportati: deepseek-v4-flash, deepseek-v4-pro
# DEEPSEEK_MODEL=deepseek-v4-flash
